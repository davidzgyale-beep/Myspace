# Required: SEC EDGAR requires every request to data.sec.gov / www.sec.gov to carry
# a descriptive User-Agent identifying the requester, per SEC's fair-access policy:
# https://www.sec.gov/os/webmaster-faq#developers
#
# Recommended format: "<App or Company Name> <contact email>"
SEC_USER_AGENT="Your Name your.email@example.com"

# Optional overrides (defaults shown)
EDGAR_CACHE_DIR=data/cache
EDGAR_RATE_LIMIT=8
