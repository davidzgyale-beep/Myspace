# Optional: identifies your requests to SEC EDGAR and other feeds per their
# fair-use policies. Recommended format: "<App or Company Name> <contact email>"
NEWS_USER_AGENT="stock-news-aggregator your.email@example.com"

# Optional: enables the Reuters/Bloomberg supplemental module via NewsAPI.org
# (https://newsapi.org/register for a free key). Leave blank/unset to skip
# these two sources -- the fetcher will not error, it just logs and continues.
NEWSAPI_KEY=

# Optional overrides (defaults shown)
NEWS_HTTP_TIMEOUT=15
FETCH_INTERVAL_MINUTES=15
